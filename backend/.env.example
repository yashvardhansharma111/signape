PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB connection URL (Atlas or self-hosted)
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/signape?retryWrites=true&w=majority
MONGODB_URI=

# JWT access token signing (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
